{
  "extends": "@sunlace/config/tsconfig.base.json",
  "compilerOptions": {
    "jsx": "react-jsx",
    "lib": ["dom", "dom.iterable", "esnext"],
    "rootDirs": ["."],
    "paths": {
      "@sunlace/ui/*": ["./src/*"],
      "@/lib/utils": ["./src/lib/utils.ts"],
      "@/components/ui/*": ["./src/components/*"]
    }
  },
  "include": ["src"]
}
