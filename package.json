{
  "name": "sunlace",
  "private": true,
  "workspaces": {
    "packages": [
      "apps/*",
      "packages/*"
    ],
    "catalog": {
      "react": "^19.2.5",
      "react-dom": "^19.2.5",
      "@types/bun": "^1.3.4",
      "@types/node": "^25.2.2",
      "@types/react": "^19.2.14",
      "@types/react-dom": "^19.2.3",
      "agentation": "^3.0.2"
    }
  },
  "type": "module",
  "scripts": {
    "check": "ultracite fix --type-aware --type-check && oxfmt --write .",
    "clean": "rm -rf node_modules apps/*/node_modules packages/*/node_modules bun.lock",
    "dev": "bun run --cwd apps/web dev",
    "build": "bun run --cwd apps/web build",
    "docker:up": "docker compose -f docker-compose.dev.yml up"
  },
  "devDependencies": {
    "@sunlace/config": "workspace:*",
    "@types/bun": "catalog:",
    "oxfmt": "^0.44.0",
    "oxlint": "1.59.0",
    "oxlint-tsgolint": "^0.20.0",
    "shadcn": "^4.11.0",
    "turbo": "^2.9.5",
    "ultracite": "7.1.5"
  },
  "overrides": {
    "oxlint": "1.59.0",
    "vite": "8.0.16"
  },
  "packageManager": "bun@1.2.23"
}
